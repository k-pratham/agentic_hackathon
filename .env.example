# =============================================================================
# Secrets Configuration — Copy to .env and fill in actual values
# =============================================================================

# Environment: dev | sit | prod
APP_ENV=dev

# Oracle Database Password
ORACLE_PASSWORD=your_oracle_password_here

# Aphrodite API Key (leave empty if no auth required)
APHRODITE_API_KEY=

# Elasticsearch Password
ES_PASSWORD=your_es_password_here
